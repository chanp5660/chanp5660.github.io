  &lt;li class=&quot;task-list-item&quot;&gt;&lt;input type=&quot;checkbox&quot; class=&quot;task-list-item-checkbox&quot; disabled=&quot;disabled&quot; /&gt;&lt;a href=&quot;https://m.blog.naver.com/muzzincys/220201299384&quot;&gt;bagging;bootstrap aggregating&lt;/a&gt;&lt;/li&gt;
